    "fault-tolerance",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.1.5",
    "nodemon": "^3.1.11"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
