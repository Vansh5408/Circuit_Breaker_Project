{
  "name": "circuit-breaker",
  "version": "1.0.0",
  "description": "Production-grade Circuit Breaker Pattern implementation with Express and MongoDB",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "node tests/circuitBreaker.test.js",
    "test:load": "node tests/loadTest.js",
    "test:load:heavy": "RPS=100 DURATION=60 node tests/loadTest.js",
    "lint": "eslint .",
    "reset": "curl -X POST http://localhost:3000/admin/reset",
    "status": "curl http://localhost:3000/admin/status | jq"
